---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolio');
  return portfolioEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${entry.data.title} · Case Study`}>
  <div class="case-study-wrapper container">
    <a href={base} class="back-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Volver al inicio
    </a>

    <div class="case-header card">
      <div class="header-content">
        <h1 class="project-title">{entry.data.title}</h1>
        <p class="project-role">{entry.data.role}</p>
        <p class="project-desc">{entry.data.description}</p>
        
        <div class="tags-row">
          {entry.data.tags.map(tag => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>

        {entry.data.liveUrl && (
          <a href={entry.data.liveUrl} target="_blank" rel="noopener" class="live-btn">
            Visitar sitio web
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        )}
      </div>
      
      <div class="header-image-wrapper">
        <img src={entry.data.image} alt={`Captura de ${entry.data.title}`} class="header-image" />
      </div>
    </div>

    <article class="case-content card">
      <Content />
    </article>
  </div>
</BaseLayout>

<style>
  .case-study-wrapper {
    padding: 120px 16px 80px;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    color: var(--muted);
    font-size: 15px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .back-btn:hover {
    color: var(--blue);
    transform: translateX(-5px);
    text-decoration: none;
  }

  .case-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    padding: 32px;
    border-radius: 24px;
    align-items: center;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .project-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
    color: var(--text);
  }

  .project-role {
    font-size: 15px;
    font-weight: 700;
    color: var(--blue);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .project-desc {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 8px;
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .project-tag {
    font-size: 12px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--blue) 12%, transparent);
    color: var(--blue);
    border: 1px solid color-mix(in oklab, var(--blue) 25%, transparent);
  }

  .live-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--blue);
    color: #fff !important;
    font-weight: 700;
    font-size: 14px;
    padding: 14px 24px;
    border-radius: 12px;
    width: fit-content;
    margin-top: 8px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(43, 107, 228, 0.3);
  }

  .live-btn:hover {
    background: var(--blue-600);
    transform: translateY(-3px);
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(43, 107, 228, 0.5);
  }

  .header-image-wrapper {
    width: 100%;
    height: 100%;
    min-height: 300px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
  }

  .header-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .case-content {
    padding: 40px;
    border-radius: 24px;
  }

  .case-content :global(h3) {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
    margin: 32px 0 16px;
    letter-spacing: -0.5px;
  }

  .case-content :global(h3:first-child) {
    margin-top: 0;
  }

  .case-content :global(p) {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text);
    margin: 0 0 20px;
  }

  .case-content :global(strong) {
    color: var(--blue);
    font-weight: 700;
  }

  .case-content :global(ul) {
    margin: 0 0 24px;
    padding-left: 24px;
  }

  .case-content :global(li) {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 8px;
  }

  .case-content :global(li::marker) {
    color: var(--blue);
  }

  @media (max-width: 768px) {
    .case-header {
      grid-template-columns: 1fr;
      padding: 24px;
    }

    .header-image-wrapper {
      min-height: 200px;
      order: -1;
    }

    .case-content {
      padding: 24px;
    }
  }
</style>